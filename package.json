{
  "name": "review-harness",
  "version": "0.1.0",
  "description": "Multi-agent AI code review CLI — runs parallel expert agents across different model families to review your diffs",
  "keywords": [
    "code-review",
    "ai",
    "cli",
    "agents",
    "openrouter",
    "llm",
    "static-analysis",
    "security"
  ],
  "author": "nayanraj210401 <nayanraj.developer@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nayanraj210401/code-review-harness.git"
  },
  "homepage": "https://github.com/nayanraj210401/code-review-harness#readme",
  "bugs": {
    "url": "https://github.com/nayanraj210401/code-review-harness/issues"
  },
  "bin": {
    "crh": "./bin/crh.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy-assets",
    "copy-assets": "mkdir -p dist/agents/builtins dist/skills/builtins dist/state && cp -r src/agents/builtins/. dist/agents/builtins/ && cp -r src/skills/builtins/. dist/skills/builtins/ && cp src/state/schema.sql dist/state/schema.sql",
    "dev": "ts-node src/cli/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^12.3.2",
    "nanoid": "^5.0.9",
    "ora": "^8.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
